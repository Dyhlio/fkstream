<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FKStream – Kodi Repository</title>
    <meta content="FKStream" property="og:title" />
    <meta content="FKStream – Repository Kodi & Add-on pour le streaming d'animes" property="og:description" />
    <meta content="#e85d04" name="theme-color" />
    <link rel="icon" type="image/x-icon" href="https://raw.githubusercontent.com/Dyhlio/fkstream/refs/heads/main/fkstream/assets/fkstream-logo.jpg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #e85d04;
            --primary-light: #f48c06;
            --bg: #0c0d13;
            --card-bg: rgba(255, 255, 255, 0.05);
            --text: #ffffff;
            --text-dim: rgba(255, 255, 255, 0.6);
            --text-muted: rgba(255, 255, 255, 0.35);
            --border: rgba(255, 255, 255, 0.1);
        }

        ::selection {
            background: rgba(232, 93, 4, 0.4);
            color: #fff;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: var(--bg);
            background-image:
                radial-gradient(at 0% 0%, rgba(232, 93, 4, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(232, 93, 4, 0.1) 0px, transparent 50%);
            color: var(--text);
            min-height: 100dvh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        .container {
            width: 100%;
            max-width: 820px;
            animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Header */
        .header {
            text-align: center;
            margin-bottom: 40px;
        }

        .logo-wrapper {
            position: relative;
            display: inline-block;
            margin-bottom: 24px;
        }

        .logo-glow {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 120%;
            height: 120%;
            background: var(--primary);
            filter: blur(30px);
            opacity: 0.3;
            z-index: -1;
            border-radius: 50%;
        }

        .logo {
            width: 88px;
            height: 88px;
            border-radius: 24px;
            border: 1px solid var(--border);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        }

        .title {
            font-size: 2.5rem;
            font-weight: 700;
            letter-spacing: -1px;
            background: linear-gradient(to bottom, #fff, #bbb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 8px;
        }

        .subtitle {
            color: var(--text-dim);
            font-size: 1rem;
            font-weight: 400;
            margin-bottom: 24px;
        }

        .about-card {
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 20px 24px;
            text-align: left;
        }

        .about-card h3 {
            color: var(--primary-light);
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .about-card p {
            color: var(--text-dim);
            font-size: 0.9rem;
            line-height: 1.7;
        }

        .about-card strong {
            color: var(--text);
        }

        /* Download cards */
        .downloads-card {
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 48px;
            margin-bottom: 16px;
        }

        .downloads-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .download-item {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 28px 24px;
            text-decoration: none;
            color: inherit;
            display: flex;
            flex-direction: column;
            gap: 16px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .download-item:hover {
            border-color: var(--primary);
            background: rgba(0, 0, 0, 0.4);
            box-shadow: 0 0 0 3px rgba(232, 93, 4, 0.15);
            transform: translateY(-2px);
        }

        .download-item:active {
            transform: translateY(0);
        }

        .download-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .download-icon {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            background: rgba(232, 93, 4, 0.1);
            border: 1px solid rgba(232, 93, 4, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .download-icon svg {
            width: 20px;
            height: 20px;
            color: var(--primary-light);
        }

        .badge {
            background: var(--primary);
            color: white;
            font-size: 0.78rem;
            font-weight: 700;
            padding: 6px 14px;
            border-radius: 10px;
            box-shadow: 0 4px 12px rgba(232, 93, 4, 0.3);
        }

        .download-name {
            font-size: 1.05rem;
            font-weight: 600;
        }

        .download-desc {
            font-size: 0.82rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        /* Footer */
        .footer {
            text-align: center;
            margin-top: 40px;
        }

        .footer-link {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.85rem;
            margin: 0 16px;
            transition: color 0.2s ease;
        }

        .footer-link:hover {
            color: var(--primary-light);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .downloads-grid { grid-template-columns: 1fr; }
            .downloads-card { padding: 28px 20px; }
            .title { font-size: 2rem; }
        }
    </style>
</head>
<body>
    <div style="display: none !important; opacity: 0; position: absolute; z-index: -100;">
        <a href="ADDON_URL">ADDON_URL</a>
        <a href="REPO_URL">REPO_URL</a>
    </div>

    <div class="container">
        <header class="header">
            <div class="logo-wrapper">
                <div class="logo-glow"></div>
                <img src="https://raw.githubusercontent.com/Dyhlio/fkstream/refs/heads/main/fkstream/assets/fkstream-logo.jpg" alt="FKStream" class="logo">
            </div>

            <h1 class="title">FKStream</h1>
            <p class="subtitle">Kodi Repository & Add-on</p>

            <div class="about-card">
                <h3>À propos</h3>
                <p>Addon <strong>non officiel</strong> pour accéder au contenu proposé par Fankai. Installez le repository pour recevoir les mises à jour automatiquement.</p>
            </div>
        </header>

        <div class="downloads-card">
            <div class="downloads-grid">
                <a href="ADDON_URL" class="download-item">
                    <div class="download-top">
                        <div class="download-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd" /></svg>
                        </div>
                        <div class="badge">vV_ADDON</div>
                    </div>
                    <div>
                        <div class="download-name">FKStream Add-on</div>
                        <div class="download-desc">Plugin Vidéo pour Kodi</div>
                    </div>
                </a>

                <a href="REPO_URL" class="download-item">
                    <div class="download-top">
                        <div class="download-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M12 2.25a.75.75 0 0 1 .75.75v11.69l3.22-3.22a.75.75 0 1 1 1.06 1.06l-4.5 4.5a.75.75 0 0 1-1.06 0l-4.5-4.5a.75.75 0 1 1 1.06-1.06l3.22 3.22V3a.75.75 0 0 1 .75-.75Zm-9 13.5a.75.75 0 0 1 .75.75v2.25a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5V16.5a.75.75 0 0 1 1.5 0v2.25a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3V16.5a.75.75 0 0 1 .75-.75Z" clip-rule="evenodd" /></svg>
                        </div>
                        <div class="badge">vV_REPO</div>
                    </div>
                    <div>
                        <div class="download-name">FKStream Repository</div>
                        <div class="download-desc">Mises à jour automatiques</div>
                    </div>
                </a>
            </div>
        </div>

        <footer class="footer">
            <a href="https://github.com/Dyhlio/fkstream" class="footer-link" target="_blank">GitHub</a>
            <a href="https://linktr.ee/FanKai" class="footer-link" target="_blank">Fankai</a>
        </footer>
    </div>
</body>
</html>
